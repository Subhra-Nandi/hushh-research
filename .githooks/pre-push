#!/bin/sh
# .githooks/pre-push -- Subtree sync guard + lint gate
#
# Ensures consent-protocol subtree is in sync with upstream before pushing.
# Install automatically via: make setup  (or: git config core.hooksPath .githooks)
#
# SYNC TRACKING: Uses a local git ref (refs/subtree-sync/consent-protocol) as a
# bookmark of the last upstream commit we synced. This works correctly with
# --squash subtree pulls (unlike git rev-list which breaks with squash merges
# because squash doesn't link commit ancestry).

# Do NOT use set -e; we handle errors explicitly with exit codes.
# set -e causes false failures with `grep -q` and `|| true` patterns.

REMOTE="$1"
URL="$2"

# Track whether consent-protocol files are in this push (top-level scope
# so both section 1 and section 2 can see it).
CP_FILES=""

# Local ref used to bookmark the last-synced upstream commit.
# Updated by `make sync-protocol` after each successful subtree pull.
SYNC_REF="refs/subtree-sync/consent-protocol"

# ─────────────────────────────────────────────────────────────────────────────
# 1. Subtree drift detection
#    If the push includes consent-protocol changes, verify upstream is merged.
# ─────────────────────────────────────────────────────────────────────────────

# Only run subtree check when pushing to origin (not consent-upstream itself).
# Use case/esac instead of echo|grep for portability and no-subshell.
case "$URL" in
  *hushh-research*)
    # Determine the commit range being pushed
    PUSH_RANGE=""
    while read local_ref local_sha remote_ref remote_sha; do
      if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        # New branch -- check all commits
        PUSH_RANGE="$local_sha"
      else
        PUSH_RANGE="$remote_sha..$local_sha"
      fi
    done

    if [ -n "$PUSH_RANGE" ]; then
      CP_FILES=$(git diff --name-only "$PUSH_RANGE" 2>/dev/null | grep "^consent-protocol/" || true)
    fi

    if [ -n "$CP_FILES" ]; then
      printf "\n\033[33m[pre-push]\033[0m Push contains consent-protocol changes.\n"

      # Check if consent-upstream remote exists
      if git remote | grep -q "consent-upstream"; then
        # Fetch upstream to compare (quick, metadata only)
        if git fetch consent-upstream main --quiet 2>/dev/null; then
          # Compare current upstream HEAD against our last-synced bookmark.
          # This correctly handles --squash subtree pulls where git rev-list
          # would falsely report upstream as "ahead" even after syncing.
          CURRENT_UPSTREAM=$(git rev-parse consent-upstream/main 2>/dev/null || echo "")
          LAST_SYNC=""
          if git show-ref --verify --quiet "$SYNC_REF" 2>/dev/null; then
            LAST_SYNC=$(git rev-parse "$SYNC_REF" 2>/dev/null || echo "")
          fi

          if [ -z "$LAST_SYNC" ]; then
            printf "\033[33m[pre-push]\033[0m No sync bookmark found (first time?).\n"
            printf "         Run: \033[36mmake sync-protocol\033[0m to set initial bookmark.\n\n"
            # Don't block on first use -- just warn so existing devs can bootstrap
          elif [ "$LAST_SYNC" != "$CURRENT_UPSTREAM" ]; then
            UPSTREAM_AHEAD=$(git rev-list "$LAST_SYNC".."$CURRENT_UPSTREAM" --count 2>/dev/null || echo "?")
            printf "\n\033[31m[pre-push] BLOCKED\033[0m consent-upstream/main is %s commit(s) ahead of last sync.\n" "$UPSTREAM_AHEAD"
            printf "         Last synced:      %s\n" "$(echo "$LAST_SYNC" | cut -c1-8)"
            printf "         Current upstream:  %s\n\n" "$(echo "$CURRENT_UPSTREAM" | cut -c1-8)"
            printf "  Run:\n"
            printf "    \033[36mmake sync-protocol\033[0m    # pull upstream + update bookmark\n"
            printf "    \033[36m# resolve conflicts if any\033[0m\n"
            printf "    \033[36mgit push\033[0m              # try again\n\n"
            exit 1
          else
            printf "\033[32m[pre-push]\033[0m Upstream is in sync. ✓\n"
            printf "         Remember to run \033[36mmake push-protocol\033[0m after PR merge.\n\n"
          fi
        else
          printf "\033[33m[pre-push]\033[0m WARNING: Could not fetch consent-upstream. Skipping sync check.\n"
          printf "         Run \033[36mmake sync-protocol\033[0m manually after push.\n\n"
        fi
      else
        printf "\033[33m[pre-push]\033[0m WARNING: consent-upstream remote not configured.\n"
        printf "         Run \033[36mmake setup\033[0m to add it.\n\n"
      fi
    fi
    ;;
esac

# ─────────────────────────────────────────────────────────────────────────────
# 2. Quick lint gate on consent-protocol (only if files changed)
# ─────────────────────────────────────────────────────────────────────────────

if [ -n "$CP_FILES" ]; then
  echo "[pre-push] Running quick lint on consent-protocol..."

  # Prefer the consent-protocol venv's Python (where ruff is installed),
  # fall back to system python3. Use .venv/bin/python3 (relative to
  # consent-protocol/) since the subshell below cd's into that directory.
  if [ -x "consent-protocol/.venv/bin/python3" ]; then
    LINT_PYTHON=".venv/bin/python3"
  elif command -v python3 >/dev/null 2>&1; then
    LINT_PYTHON="python3"
  else
    LINT_PYTHON=""
  fi

  if [ -n "$LINT_PYTHON" ]; then
    # Run in a subshell so `cd` doesn't affect the caller on failure
    (cd consent-protocol && "$LINT_PYTHON" -m ruff check . && "$LINT_PYTHON" -m ruff format --check .) || {
      echo ""
      echo "[pre-push] Lint failed. Run: cd consent-protocol && make fix"
      exit 1
    }
  else
    echo "[pre-push] WARNING: python3 not found, skipping lint."
  fi
fi
